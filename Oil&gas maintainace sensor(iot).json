    {
      "parameters": {
        "content": "Decision Logic\nThe Filter: A decision node checks if the Status == ALERT? based on pre-set safety thresholds.\n\nNegative Path: If the status is \"No\" (Normal), the workflow reaches its End with no further action taken.",
        "height": 256
      },
      "type": "n8n-nodes-base.stickyNote",
