      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "content": "AI-Powered Response\nAI Integration: If an alert is triggered, an LLM (AI Chain) analyzes the data.\n\nOutput: Generates a Technical Maintenance Advisory (suggests specific repair steps).\n\nDispatch: Alerts are sent immediately via Gmail and Slack to the maintenance team.",
        "height": 272
      },
